{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/restayway/regbot/main/schema/regbot.v1.schema.json",
  "title": "Regbot v1 configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "registries", "policies"],
  "properties": {
    "version": { "const": "v1" },
    "apply": { "type": "boolean", "default": false },
    "registries": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/registry" }
    },
    "policies": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/policy" }
    },
    "hooks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "after_apply": { "$ref": "#/$defs/webhook" }
      }
    }
  },
  "$defs": {
    "duration": {
      "type": "string",
      "pattern": "^(0|[0-9]+(ns|us|µs|ms|s|m|h))+$"
    },
    "registry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider"],
      "properties": {
        "provider": { "enum": ["oci", "github"] },
        "endpoint": { "type": "string", "format": "uri" },
        "owner": { "type": "string", "minLength": 1 },
        "owner_type": { "enum": ["organization", "user"] },
        "token_env": { "type": "string" },
        "token_file": { "type": "string" },
        "repositories": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "credentials": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "username_env": { "type": "string" },
            "username_file": { "type": "string" },
            "password_env": { "type": "string" },
            "password_file": { "type": "string" }
          }
        },
        "tls": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ca_file": { "type": "string" },
            "insecure_skip_verify": { "type": "boolean", "default": false }
          }
        },
        "timeout": { "$ref": "#/$defs/duration" }
      },
      "allOf": [
        {
          "if": { "properties": { "provider": { "const": "oci" } } },
          "then": { "required": ["endpoint"] }
        },
        {
          "if": { "properties": { "provider": { "const": "github" } } },
          "then": { "required": ["owner", "owner_type"] }
        }
      ]
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["registry", "repositories"],
      "properties": {
        "registry": { "type": "string", "minLength": 1 },
        "repositories": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "include": { "type": "array", "items": { "type": "string" } },
            "exclude": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targets", "tags", "retention", "safety"],
      "properties": {
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/target" }
        },
        "tags": {
          "type": "object",
          "additionalProperties": false,
          "required": ["parser"],
          "properties": {
            "parser": { "enum": ["calendar", "custom_regex"] },
            "patterns": {
              "type": "array",
              "items": {
                "enum": ["vYYYY.MM.DD.x", "vYYYY.MM.DD.x-{app}"]
              }
            },
            "regex": { "type": "string" }
          },
          "allOf": [
            {
              "if": { "properties": { "parser": { "const": "custom_regex" } } },
              "then": { "required": ["regex"] }
            },
            {
              "if": { "properties": { "parser": { "const": "calendar" } } },
              "then": { "not": { "required": ["regex"] } }
            }
          ]
        },
        "retention": {
          "type": "object",
          "additionalProperties": false,
          "required": ["delete_older_than", "keep_at_least"],
          "properties": {
            "keep_newer_than": { "$ref": "#/$defs/duration" },
            "delete_older_than": { "$ref": "#/$defs/duration" },
            "keep_latest": { "type": "integer", "minimum": 0 },
            "keep_at_least": { "type": "integer", "minimum": 1 },
            "group_by": { "enum": ["app"] }
          }
        },
        "protect": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "tags": { "type": "array", "items": { "type": "string" } },
            "tag_patterns": { "type": "array", "items": { "type": "string" } },
            "digests": { "type": "array", "items": { "type": "string" } },
            "unparsed_tags": { "type": "boolean", "default": true }
          }
        },
        "safety": {
          "type": "object",
          "additionalProperties": false,
          "required": ["max_delete_count", "max_delete_percent"],
          "properties": {
            "max_delete_count": { "type": "integer", "minimum": 1 },
            "max_delete_percent": {
              "type": "number",
              "exclusiveMinimum": 0,
              "maximum": 100
            },
            "require_tagged_artifact": { "type": "boolean", "default": true }
          }
        }
      }
    },
    "webhook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "url_env"],
      "properties": {
        "type": { "const": "webhook" },
        "url_env": { "type": "string", "minLength": 1 },
        "bearer_token_env": { "type": "string" },
        "hmac_secret_env": { "type": "string" },
        "timeout": { "$ref": "#/$defs/duration" }
      }
    }
  }
}
